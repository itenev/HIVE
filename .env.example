# HIVE Environment Variables
# Copy this file to `.env` and fill in your values.
# The .env file is gitignored and will not be committed.

# Discord bot token (required for Discord platform)
DISCORD_TOKEN=your_discord_bot_token_here

# Comma-separated list of Discord User IDs that have admin access.
# Admins can use /clean, /sweep, /stop, admin-only tools, and DM the bot directly.
# local_admin and apis_autonomy are always added automatically.
HIVE_ADMIN_USERS=your_discord_user_id_here

# The Discord channel ID the bot listens to for public messages.
# The bot will respond to messages in this channel + DMs from admins + @mentions anywhere.
# HIVE_CHAT_CHANNEL=your_chat_channel_id       # Channel Apis LISTENS to for messages
# HIVE_TARGET_CHANNEL=your_autonomy_channel_id  # Channel Apis POSTS autonomy events to

# Main inference model (default: qwen3.5:35b)
# HIVE_MODEL takes precedence; OLLAMA_MODEL is also accepted as an alias.
# HIVE_MODEL=qwen3.5:35b

# Observer/Self-Check model (default: same as main model)
# Runs on every response to review quality. A smaller/faster model
# reduces per-turn latency without affecting response quality.
# HIVE_OBSERVER_MODEL=qwen3.5:9b

# Glasses platform model (default: qwen3.5:9b — fast for voice)
# HIVE_GLASSES_MODEL=qwen3.5:9b

# Reasoning Router — dynamic model selection per message (default: disabled)
# When enabled, uses a small classifier to route messages to the right model:
#   low complexity → small model, medium → default model, high → large model
# Requires enough RAM for all three models simultaneously.
# Set to false if you only have one model loaded.
# HIVE_ROUTER_ENABLED=false
# HIVE_ROUTER_MODEL=qwen3.5:9b        # Classifier model (fast, thinking off)
# HIVE_LOW_MODEL=qwen3.5:9b            # Simple tasks
# HIVE_MEDIUM_MODEL=qwen3.5:35b        # Default / moderate tasks
# HIVE_HIGH_MODEL=qwen3.5:122b         # Complex reasoning

# Ollama server URL (default: http://localhost:11434)
# Override for remote Ollama or multi-container Docker setups.
# HIVE_OLLAMA_URL=http://localhost:11434

# Serial inference mode (default: true)
# Forces all Ollama calls to queue one-at-a-time. Required when the active model
# does not support parallel inference (e.g., qwen3.5 on Ollama as of March 2026).
# Set to false when Ollama adds parallel support for the model to restore concurrency.
# HIVE_SERIAL_INFERENCE=true

# Max parallel inference slots (only used when HIVE_SERIAL_INFERENCE=false)
# HIVE_MAX_PARALLEL=16

# Glasses WebSocket port (default: 8421)
# HIVE_GLASSES_PORT=8421

# Glasses auth token — if set, clients must include ?token=<this> to connect
# Leave unset for dev mode (accepts all connections)
# HIVE_GLASSES_TOKEN=

# File server port (default: 8420)
# HIVE_FILE_SERVER_PORT=8420

# File server auth token
# HIVE_FILE_TOKEN=

# Python binary path (default: python3)
# HIVE_PYTHON_BIN=python3

# Training backend (default: auto)
# auto  = MLX on macOS (Apple Silicon), torch on Linux/Windows
# mlx   = Force MLX (Apple Silicon only — requires mlx-lm-lora)
# torch = Force PyTorch (CUDA/MPS/CPU — requires transformers, peft, trl)
# HIVE_TRAINING_BACKEND=auto

# ─── SafeNet P2P Mesh ────────────────────────────────

# Apis-to-Apis mesh chat
# HIVE_MESH_CHAT_LISTEN=false        # Listen to incoming mesh chat messages
# HIVE_MESH_CHAT_DISCORD_CHANNEL=    # Discord channel ID to bridge mesh chat
# HIVE_MESH_CHAT_NAME=Apis           # Display name on the mesh

# SafeNet (Human P2P)
# HIVE_SAFENET_ENABLED=false          # Enable SafeNet HumanMesh
# HIVE_SAFENET_PORT=9877              # SafeNet listen port

# Apis-Book (One-Way Mirror)
# HIVE_APIS_BOOK_ENABLED=true         # Read-only AI mesh observation dashboard
# HIVE_APIS_BOOK_PORT=3031            # Apis-Book dashboard port

# Web Proxy (Censorship Resistance)
# HIVE_WEB_PROXY_ENABLED=false        # Enable the web proxy
# HIVE_WEB_PROXY_PORT=8480            # Proxy listen port
# HIVE_WEB_PROXY_MESH_RELAY=false     # Enable mesh relay when clearnet is down
# HIVE_WEB_PROXY_CACHE=true           # Cache fetched pages
# HIVE_DOH_RESOLVER=https://cloudflare-dns.com/dns-query  # DNS-over-HTTPS resolver

# Offline Mesh (Store-and-Forward)
# HIVE_OFFLINE_MAX_QUEUE=1000         # Max queued messages when offline
# HIVE_OFFLINE_TTL_HOURS=72           # How long to keep trying (3 days default)

# Resource Pooling (Equality Collective — ON by default)
# HIVE_WEB_SHARE_ENABLED=true            # Share your internet with the mesh
# HIVE_WEB_SHARE_MAX_REQ_HOUR=100        # Max relay requests you'll serve per hour
# HIVE_COMPUTE_SHARE_ENABLED=true        # Share your compute with the mesh
# HIVE_COMPUTE_SHARE_MAX_SLOTS=2         # Max concurrent remote inference jobs
# HIVE_COMPUTE_SHARE_MAX_TOKENS_HOUR=50000  # Max tokens/hour for remote peers
# HIVE_MESH_CHAT_DISCORD_CHANNEL=1487802381537116211  # Apis mesh chat bridge

# HiveSurface — Decentralised Social Web
# HIVE_SURFACE_PORT=3032                 # Port for HiveSurface (default: 3032)
# HIVE_SURFACE_MAX_POSTS=10000           # Ring buffer size for social feed
# HIVE_SURFACE_PERSIST=memory/mesh_posts.json  # Where to persist posts

# Apis Code — AI-Powered Web IDE
# HIVE_CODE_PORT=3033                    # Port for Apis Code IDE (default: 3033)
# HIVE_CODE_WORKSPACE=.                  # Workspace root (default: HIVE project root)

# HiveChat — Decentralised Discord Clone
# HIVE_CHAT_PORT=3034                    # Port for HiveChat (default: 3034)
# HIVE_CHAT_MAX_MESSAGES=5000            # Ring buffer size per channel
# HIVE_USER_NAME=                        # Your display name in chat

# HivePortal — Mesh Homepage & App Launcher
# HIVE_PORTAL_PORT=3035                  # Port for HivePortal (default: 3035)

# ── Credits System ──────────────────────────────────────────
HIVE_CREDITS_ENABLED=true
HIVE_CREDITS_WELCOME_BONUS=100
HIVE_CREDITS_COMPUTE_EARN_PER_1K=2.0
HIVE_CREDITS_NETWORK_EARN_PER_100=1.0
HIVE_CREDITS_IDLE_EARN_PER_HOUR=0.5
HIVE_CREDITS_HIGH_DEMAND_MULTIPLIER=1.5
HIVE_CREDITS_MODERATE_DEMAND_MULTIPLIER=1.2
HIVE_CREDITS_SOCIAL_SHARE_MAX_PER_DAY=5
HIVE_CREDITS_CODE_CONTRIBUTION_BASE=10.0
HIVE_CREDITS_SOCIAL_SHARE_EARN=3.0
HIVE_CREDITS_COMMUNITY_VOTE_EARN=1.0
HIVE_CREDITS_GOVERNANCE_VOTE_EARN=2.0
HIVE_CREDITS_CONTENT_CONTRIBUTION_EARN=2.0
HIVE_CREDITS_COMPUTE_COST_PER_1K=1.0
HIVE_CREDITS_NETWORK_COST_PER_100=0.5
HIVE_CREDITS_PRIORITY_BOOST_COST=5.0

# ── Marketplace ─────────────────────────────────────────────
HIVE_MARKETPLACE_PORT=3038
HIVE_MARKETPLACE_MAX_LISTINGS_PER_PEER=50
HIVE_MARKETPLACE_REVIEW_MIN_LENGTH=10

# ── Access Queue ────────────────────────────────────────────
HIVE_QUEUE_FREE_MAX_CONCURRENT=3
HIVE_QUEUE_PRIORITY_DURATION_SECS=300
HIVE_QUEUE_REPUTATION_BOOST=0.8
